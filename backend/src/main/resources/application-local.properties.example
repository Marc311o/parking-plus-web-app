# Copy this file to application-local.properties (which is gitignored) and fill in your local values.
# Alternatively, set these as environment variables.

# JWT signing secret - use a long, random string in production
JWT_SECRET=replace-with-a-long-random-secret

# SMTP credentials for password reset emails
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# Admin account bootstrap credentials (used by DataInitializer on first run)
APP_ADMIN_EMAIL=admin@parking.pl
APP_ADMIN_PASSWORD=replace-with-secure-password

# Frontend base URL used in password reset links
app.frontendBaseUrl=http://localhost:5173
